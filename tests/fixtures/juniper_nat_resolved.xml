<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
                <address-book>
                    <address>
                        <name>client-net</name>
                        <ip-prefix>10.0.0.0/24</ip-prefix>
                    </address>
                    <address>
                        <name>partner-net</name>
                        <ip-prefix>172.16.0.0/24</ip-prefix>
                    </address>
                </address-book>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <nat>
            <source>
                <pool>
                    <name>range-snat</name>
                    <description>SNAT address range</description>
                    <address-range>
                        <low>198.51.100.20/32</low>
                        <high>198.51.100.30/32</high>
                    </address-range>
                </pool>
                <rule-set>
                    <name>trust-to-untrust</name>
                    <from>
                        <zone>trust</zone>
                    </from>
                    <to>
                        <zone>untrust</zone>
                    </to>
                    <rule>
                        <name>snat-any</name>
                        <then>
                            <source-nat>
                                <pool>range-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                    <rule>
                        <name>snat-source-only</name>
                        <match>
                            <source-address>client-net</source-address>
                        </match>
                        <then>
                            <source-nat>
                                <pool>range-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                    <rule>
                        <name>snat-app</name>
                        <match>
                            <source-address>client-net</source-address>
                            <application>tcp-8080</application>
                        </match>
                        <then>
                            <source-nat>
                                <pool>range-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                    <rule>
                        <name>snat-mixed</name>
                        <match>
                            <destination-address>partner-net</destination-address>
                            <application>rpc-app</application>
                            <protocol>udp</protocol>
                            <destination-port>53</destination-port>
                        </match>
                        <then>
                            <source-nat>
                                <pool>range-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                </rule-set>
            </source>
            <destination>
                <pool>
                    <name>web-dnat-range</name>
                    <description>DNAT address range</description>
                    <address-range>
                        <low>10.10.10.10/32</low>
                        <high>10.10.10.12/32</high>
                    </address-range>
                    <port>8443</port>
                </pool>
                <rule-set>
                    <name>public-services</name>
                    <from>
                        <zone>untrust</zone>
                    </from>
                    <rule>
                        <name>dnat-app-only</name>
                        <match>
                            <destination-address>203.0.113.10/32</destination-address>
                            <application>tcp-8443</application>
                        </match>
                        <then>
                            <destination-nat>
                                <pool>web-dnat-range</pool>
                            </destination-nat>
                        </then>
                    </rule>
                </rule-set>
            </destination>
        </nat>
    </security>
    <applications>
        <application>
            <name>tcp-8080</name>
            <protocol>tcp</protocol>
            <destination-port>8080</destination-port>
        </application>
        <application>
            <name>rpc-app</name>
            <protocol>tcp</protocol>
            <source-port>1024-65535</source-port>
            <destination-port>111</destination-port>
        </application>
        <application>
            <name>tcp-8443</name>
            <protocol>tcp</protocol>
            <destination-port>8443</destination-port>
        </application>
    </applications>
</configuration>
