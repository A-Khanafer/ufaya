<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
                <address-book>
                    <address>
                        <name>web-server</name>
                        <ip-prefix>10.0.1.10/32</ip-prefix>
                    </address>
                    <address>
                        <name>db-server</name>
                        <ip-prefix>10.0.1.20/32</ip-prefix>
                    </address>
                    <address>
                        <name>app-server</name>
                        <ip-prefix>10.0.1.30/32</ip-prefix>
                    </address>
                    <address-set>
                        <name>servers</name>
                        <address>
                            <name>web-server</name>
                        </address>
                        <address>
                            <name>db-server</name>
                        </address>
                    </address-set>
                    <address-set>
                        <name>all-servers</name>
                        <address>
                            <name>app-server</name>
                        </address>
                        <address-set>
                            <name>servers</name>
                        </address-set>
                    </address-set>
                </address-book>
            </security-zone>
            <security-zone>
                <name>untrust</name>
                <address-book>
                    <address>
                        <name>external-dns</name>
                        <ip-prefix>8.8.8.8/32</ip-prefix>
                    </address>
                </address-book>
            </security-zone>
            <security-zone>
                <name>dmz</name>
                <address-book>
                    <address>
                        <name>dmz-web</name>
                        <ip-prefix>172.16.0.10/32</ip-prefix>
                    </address>
                </address-book>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust</from-zone-name>
                <to-zone-name>untrust</to-zone-name>
                <policy>
                    <name>allow-dns</name>
                    <description>Allow DNS to external servers</description>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>external-dns</destination-address>
                        <application>junos-dns-udp</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>allow-web</name>
                    <match>
                        <source-address>servers</source-address>
                        <destination-address>any</destination-address>
                        <application>junos-http</application>
                        <application>junos-https</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
                <policy>
                    <name>deny-all</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <deny/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
            </policy>
            <policy>
                <from-zone-name>untrust</from-zone-name>
                <to-zone-name>dmz</to-zone-name>
                <policy>
                    <name>allow-inbound-web</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>dmz-web</destination-address>
                        <application>web-apps</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>reject-rest</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <reject/>
                    </then>
                </policy>
            </policy>
            <global>
                <policy>
                    <name>global-deny</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <deny/>
                    </then>
                </policy>
            </global>
        </policies>
    </security>
    <applications>
        <application>
            <name>custom-ssh</name>
            <protocol>tcp</protocol>
            <destination-port>2222</destination-port>
        </application>
        <application>
            <name>custom-app</name>
            <protocol>tcp</protocol>
            <destination-port>8080</destination-port>
        </application>
        <application-set>
            <name>web-apps</name>
            <application>
                <name>junos-http</name>
            </application>
            <application>
                <name>junos-https</name>
            </application>
            <application>
                <name>custom-app</name>
            </application>
        </application-set>
    </applications>
</configuration>
