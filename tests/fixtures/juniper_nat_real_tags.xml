<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
                <address-book>
                    <address>
                        <name>client-net</name>
                        <ip-prefix>10.0.0.0/24</ip-prefix>
                    </address>
                    <address>
                        <name>guest-net</name>
                        <ip-prefix>10.1.0.0/24</ip-prefix>
                    </address>
                    <address>
                        <name>partner-net</name>
                        <ip-prefix>172.16.0.0/24</ip-prefix>
                    </address>
                </address-book>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <address-book>
            <name>global</name>
            <address>
                <name>internal-web</name>
                <ip-prefix>10.10.10.10/32</ip-prefix>
            </address>
        </address-book>
        <nat>
            <source>
                <pool>
                    <name>internet-snat</name>
                    <description>SNAT pool for internet egress</description>
                    <address>198.51.100.10/32</address>
                </pool>
                <rule-set>
                    <name>trust-to-untrust</name>
                    <from>
                        <zone>trust</zone>
                    </from>
                    <to>
                        <zone>untrust</zone>
                    </to>
                    <rule>
                        <name>snat-pool</name>
                        <description>Translate trust clients to internet pool</description>
                        <src-nat-rule-match>
                            <source-address>
                                <name>client-net</name>
                            </source-address>
                            <destination-address>
                                <name>any</name>
                            </destination-address>
                        </src-nat-rule-match>
                        <then>
                            <source-nat>
                                <pool>internet-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                    <rule>
                        <name>snat-interface</name>
                        <src-nat-rule-match>
                            <source-address-name>
                                <name>guest-net</name>
                            </source-address-name>
                            <destination-address>
                                <name>any</name>
                            </destination-address>
                            <protocol>tcp</protocol>
                        </src-nat-rule-match>
                        <then>
                            <source-nat>
                                <interface/>
                            </source-nat>
                        </then>
                    </rule>
                    <rule>
                        <name>snat-any</name>
                        <then>
                            <source-nat>
                                <pool>internet-snat</pool>
                            </source-nat>
                        </then>
                    </rule>
                    <rule inactive="inactive">
                        <name>snat-off</name>
                        <src-nat-rule-match>
                            <source-address>
                                <name>any</name>
                            </source-address>
                            <destination-address-name>
                                <name>partner-net</name>
                            </destination-address-name>
                        </src-nat-rule-match>
                        <then>
                            <source-nat>
                                <off/>
                            </source-nat>
                        </then>
                    </rule>
                </rule-set>
            </source>
            <destination>
                <pool>
                    <name>web-dnat</name>
                    <description>Forward public HTTPS to internal web server</description>
                    <address>10.10.10.10/32</address>
                    <port>8443</port>
                </pool>
                <rule-set>
                    <name>public-services</name>
                    <from>
                        <zone>untrust</zone>
                    </from>
                    <rule>
                        <name>dnat-web</name>
                        <description>Publish internal web service</description>
                        <dest-nat-rule-match>
                            <destination-address>
                                <name>203.0.113.10/32</name>
                            </destination-address>
                            <destination-port>443</destination-port>
                            <protocol>tcp</protocol>
                        </dest-nat-rule-match>
                        <then>
                            <destination-nat>
                                <pool>web-dnat</pool>
                            </destination-nat>
                        </then>
                    </rule>
                </rule-set>
            </destination>
            <static>
                <rule-set>
                    <name>static-public</name>
                    <from>
                        <zone>untrust</zone>
                    </from>
                    <rule>
                        <name>static-web</name>
                        <static-nat-rule-match>
                            <destination-address>
                                <name>198.51.100.200/32</name>
                            </destination-address>
                        </static-nat-rule-match>
                        <then>
                            <static-nat>
                                <prefix-name>internal-web</prefix-name>
                                <mapped-port>9443</mapped-port>
                            </static-nat>
                        </then>
                    </rule>
                </rule-set>
            </static>
        </nat>
    </security>
</configuration>
