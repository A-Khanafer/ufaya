<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust</from-zone-name>
                <to-zone-name>untrust</to-zone-name>
                <policy>
                    <name>init-only</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>init-and-close</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                            <session-close/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>no-log</name>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
            </policy>
        </policies>
    </security>
</configuration>
