<rpc-reply>
    <configuration>
        <security>
            <zones>
                <security-zone>
                    <name>trust</name>
                </security-zone>
                <security-zone>
                    <name>untrust</name>
                </security-zone>
            </zones>
            <policies>
                <policy>
                    <from-zone-name>trust</from-zone-name>
                    <to-zone-name>untrust</to-zone-name>
                    <policy>
                        <name>simple-permit</name>
                        <match>
                            <source-address>any</source-address>
                            <destination-address>any</destination-address>
                            <application>any</application>
                        </match>
                        <then>
                            <permit/>
                        </then>
                    </policy>
                </policy>
            </policies>
        </security>
    </configuration>
</rpc-reply>
