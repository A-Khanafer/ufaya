<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
                <address-book>
                    <address>
                        <name>addr-a</name>
                        <ip-prefix>10.1.0.0/16</ip-prefix>
                    </address>
                    <address>
                        <name>addr-b</name>
                        <ip-prefix>10.2.0.0/16</ip-prefix>
                    </address>
                    <address>
                        <name>addr-c</name>
                        <ip-prefix>10.3.0.0/16</ip-prefix>
                    </address>
                    <address-set>
                        <name>set-inner</name>
                        <address>
                            <name>addr-a</name>
                        </address>
                        <address>
                            <name>addr-b</name>
                        </address>
                    </address-set>
                    <address-set>
                        <name>set-outer</name>
                        <address>
                            <name>addr-c</name>
                        </address>
                        <address-set>
                            <name>set-inner</name>
                        </address-set>
                    </address-set>
                </address-book>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust</from-zone-name>
                <to-zone-name>untrust</to-zone-name>
                <policy>
                    <name>recursive-set-rule</name>
                    <match>
                        <source-address>set-outer</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
            </policy>
        </policies>
    </security>
</configuration>
