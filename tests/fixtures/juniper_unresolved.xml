<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust</name>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust</from-zone-name>
                <to-zone-name>untrust</to-zone-name>
                <policy>
                    <name>unresolved-rule</name>
                    <match>
                        <source-address>mystery-host</source-address>
                        <destination-address>unknown-net</destination-address>
                        <application>custom-undefined</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
            </policy>
        </policies>
    </security>
</configuration>
