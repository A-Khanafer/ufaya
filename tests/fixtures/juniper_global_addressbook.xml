<configuration>
    <security>
        <address-book>
            <name>global</name>
            <address>
                <name>global-server</name>
                <ip-prefix>192.168.100.1/32</ip-prefix>
            </address>
            <address>
                <name>global-net</name>
                <ip-prefix>192.168.200.0/24</ip-prefix>
            </address>
            <address-set>
                <name>global-group</name>
                <address>
                    <name>global-server</name>
                </address>
                <address>
                    <name>global-net</name>
                </address>
            </address-set>
        </address-book>
        <zones>
            <security-zone>
                <name>trust</name>
            </security-zone>
            <security-zone>
                <name>untrust</name>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust</from-zone-name>
                <to-zone-name>untrust</to-zone-name>
                <policy>
                    <name>use-global-addr</name>
                    <match>
                        <source-address>global-group</source-address>
                        <destination-address>any</destination-address>
                        <application>any</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
            </policy>
        </policies>
    </security>
</configuration>
