<configuration>
    <security>
        <zones>
            <security-zone>
                <name>trust-intranet</name>
            </security-zone>
            <security-zone>
                <name>untrust-intranet</name>
            </security-zone>
        </zones>
        <policies>
            <policy>
                <from-zone-name>trust-intranet</from-zone-name>
                <to-zone-name>untrust-intranet</to-zone-name>
                <policy>
                    <name>10</name>
                    <description>S1 Access</description>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>34.235.81.227/32</destination-address>
                        <application>tcp-443</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>25</name>
                    <description>Test Internet IP with ipv4.telnetmyip.com</description>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>3.19.111.8/32</destination-address>
                        <application>tcp-23</application>
                        <application>tcp-22</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>40</name>
                    <description>Public DNS from VLAB DNS</description>
                    <match>
                        <source-address>10.20.20.20/32</source-address>
                        <source-address>10.40.20.20/32</source-address>
                        <destination-address>207.164.234.193/32</destination-address>
                        <destination-address>207.164.234.129/32</destination-address>
                        <application>tcp-53</application>
                        <application>udp-53</application>
                        <application>icmpv4</application>
                    </match>
                    <then>
                        <permit/>
                        <log>
                            <session-init/>
                        </log>
                    </then>
                </policy>
                <policy>
                    <name>50</name>
                    <description>Richer term fields</description>
                    <match>
                        <source-address>any</source-address>
                        <destination-address>any</destination-address>
                        <application>sunrpc-app</application>
                    </match>
                    <then>
                        <permit/>
                    </then>
                </policy>
            </policy>
        </policies>
    </security>
    <applications>
        <application>
            <name>tcp-443</name>
            <protocol>tcp</protocol>
            <destination-port>443</destination-port>
        </application>
        <application>
            <name>tcp-23</name>
            <protocol>tcp</protocol>
            <destination-port>23</destination-port>
        </application>
        <application>
            <name>tcp-22</name>
            <protocol>tcp</protocol>
            <destination-port>22</destination-port>
        </application>
        <application>
            <name>tcp-53</name>
            <protocol>tcp</protocol>
            <destination-port>53</destination-port>
        </application>
        <application>
            <name>udp-53</name>
            <protocol>udp</protocol>
            <destination-port>53</destination-port>
        </application>
        <application>
            <name>icmpv4</name>
            <term>
                <name>echo</name>
                <protocol>icmp</protocol>
                <icmp-type>8</icmp-type>
                <icmp-code>0</icmp-code>
            </term>
            <term>
                <name>traceroute</name>
                <protocol>udp</protocol>
                <destination-port>33434-33534</destination-port>
            </term>
            <term>
                <name>echo-duplicate</name>
                <protocol>icmp</protocol>
                <icmp-type>8</icmp-type>
                <icmp-code>0</icmp-code>
            </term>
            <term>
                <name>unreachable</name>
                <protocol>icmp</protocol>
                <icmp-type>3</icmp-type>
            </term>
        </application>
        <application>
            <name>sunrpc-app</name>
            <protocol>tcp</protocol>
            <source-port>1024-65535</source-port>
            <destination-port>111</destination-port>
            <alg>sunrpc</alg>
            <rpc-program-number>100000</rpc-program-number>
            <inactivity-timeout>300</inactivity-timeout>
        </application>
    </applications>
</configuration>
